# Serves the matching .html file for clean URLs (e.g. /work -> work.html)
# without changing what shows in the address bar. Mirrors vercel.json's
# rewrites for Apache/LiteSpeed hosting (e.g. Hostinger).

RewriteEngine On

RewriteRule ^work/?$ /work.html [L,QSA]
RewriteRule ^sample-project/?$ /sample-project.html [L,QSA]
RewriteRule ^project/?$ /project.html [L,QSA]
RewriteRule ^studio/?$ /studio.html [L,QSA]
RewriteRule ^services/?$ /services.html [L,QSA]
RewriteRule ^pricing/?$ /pricing.html [L,QSA]
RewriteRule ^journal/?$ /journal.html [L,QSA]
RewriteRule ^legal/?$ /legal.html [L,QSA]
RewriteRule ^contact/?$ /contact.html [L,QSA]

RewriteRule ^ka/?$ /ka/index.html [L,QSA]
RewriteRule ^ka/work/?$ /ka/work.html [L,QSA]
RewriteRule ^ka/sample-project/?$ /ka/sample-project.html [L,QSA]
RewriteRule ^ka/project/?$ /ka/project.html [L,QSA]
RewriteRule ^ka/studio/?$ /ka/studio.html [L,QSA]
RewriteRule ^ka/services/?$ /ka/services.html [L,QSA]
RewriteRule ^ka/pricing/?$ /ka/pricing.html [L,QSA]
RewriteRule ^ka/journal/?$ /ka/journal.html [L,QSA]
RewriteRule ^ka/legal/?$ /ka/legal.html [L,QSA]
RewriteRule ^ka/contact/?$ /ka/contact.html [L,QSA]
