# Copy to .env for local dev (used only by `vercel dev`, not plain `vite`).
# In production, set these same names in Vercel → Project Settings → Environment Variables.

# Settings → API in your Supabase project dashboard
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Settings → API → "anon" / "public" key — safe to expose in browser code
SUPABASE_ANON_KEY=

# Settings → API → "service_role" key — SERVER ONLY, bypasses row-level security.
# Never import this in client-side JS, only inside files under /api.
SUPABASE_SERVICE_ROLE_KEY=
